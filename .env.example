# =========================
# Application
# =========================
APP_NAME=StreamPlatform
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
APP_ENV=local
# APP_ENV=production

# =========================
# Database
# =========================
POSTGRES_USER=stream
POSTGRES_PASSWORD=stream
POSTGRES_DB=streamdb
DATABASE_URL=postgresql+asyncpg://stream:stream@postgres:5432/streamdb

# =========================
# Redis
# =========================
REDIS_URL=redis://redis:6379/0

# =========================
# Storage Backend
# Choose one of: local, s3, azure, gcs
# =========================
STORAGE_BACKEND=local
LOCAL_MEDIA_PATH=/media

# -- CDN (optional, for cloud storage in production) --
# CDN_URL=https://cdn.example.com

# -- AWS S3 --
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=my-streaming-bucket
# S3_ENDPOINT_URL=              # for MinIO / S3-compatible
# S3_PRESIGNED_URL_EXPIRY=3600

# -- Azure Blob Storage --
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_CONTAINER_NAME=media

# -- Google Cloud Storage --
# GCS_BUCKET_NAME=my-streaming-bucket
# GCS_CREDENTIALS_PATH=/secrets/gcs-key.json

# =========================
# Transcoding
# =========================
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
TRANSCODE_SEGMENT_DURATION=4
HLS_SEGMENT_TYPE=fmp4

# =========================
# Live Streaming
# =========================
RTMP_PORT=1935
LIVE_HLS_PATH=/media/live

# =========================
# Metadata Enrichment (optional — if missing, admin fills manually)
# =========================
# Get free API key at: https://www.omdbapi.com/apikey.aspx
# OMDB_API_KEY=
# Get free API key at: https://www.themoviedb.org/settings/api
# TMDB_API_KEY=

# =========================
# Auth
# =========================
JWT_SECRET_KEY=change-me-in-production-use-a-strong-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================
# OTP / Email
# =========================
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
# SMTP_USE_TLS=true

# -- Google OAuth --
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback

# -- Facebook OAuth --
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# FACEBOOK_REDIRECT_URI=http://localhost:8080/api/v1/auth/facebook/callback

# -- Frontend URL (for OAuth redirects) --
FRONTEND_URL=http://localhost:5173

# =========================
# AI Service
# =========================
AI_SERVICE_URL=http://ai:8100

# LLM Provider: local | anthropic | openai | ollama
# Default "local" uses a GGUF model via llama-cpp-python (no API key needed)
# Switch to "anthropic" or "openai" for cloud-hosted LLM
LLM_PROVIDER=local
DEFAULT_LOCAL_MODEL=qwen2.5-3b
LOCAL_LLM_THREADS=4

# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20241022

# -- OpenAI fallback --
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# -- Ollama fallback (local, free) --
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1

# Embedding model (runs locally in AI service, no API key needed)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# =========================
# Recommendations
# =========================
# RECOMMENDATION_CACHE_TTL=300
# RECOMMENDATION_LIMIT=12

# =========================
# Default Admin (seed)
# =========================
ADMIN_EMAIL=admin@streamplatform.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# =========================
# Frontend (Vite env vars)
# =========================
VITE_API_URL=http://localhost:8080/api/v1
VITE_WS_URL=ws://localhost:8080/ws
VITE_MEDIA_URL=http://localhost:8080/media
VITE_LIVE_URL=http://localhost:8080/live
